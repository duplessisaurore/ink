# Maintainer: Aurore du Plessis <aurore@sudlicht.com>

pkgname=lepton3
_pkgname=lepton3
pkgver=1.0.0
pkgrel=1
pkgdesc="A bytecode virtual machine for embedded systems"
arch=('x86_64')
url="https://github.com/duplessisaurore/lepton3"
license=('AGPLv3')
depends=()
makedepends=('rust' 'cargo' 'git')
source=("$_pkgname::git+https://github.com/duplessisaurore/lepton3.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$_pkgname"
  grep '^version' Cargo.toml | head -n1 | cut -d'"' -f2 || echo "1.0.0"
}

build() {
  cd "$srcdir/$_pkgname"
  cargo build -p lepton_std --release
}

check() {
  cd "$srcdir/$_pkgname"
  cargo test -p lepton_std --release || true
}

package() {
  cd "$srcdir/$_pkgname"
  install -Dm755 "target/release/lepton_std" "$pkgdir/usr/bin/lepton3"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}