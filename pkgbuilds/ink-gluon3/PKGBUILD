# Maintainer: Aurore du Plessis <aurore@sudlicht.com>

pkgname=ink-gluon3
_pkgname=gluon3
pkgver=1.1.0
pkgrel=1
pkgdesc="A file combiner/linker for the Boson3 sugared language."
arch=('x86_64')
url="https://github.com/duplessisaurore/quark3"
license=('AGPLv3')
depends=()
makedepends=('rust' 'cargo' 'git')
source=("$_pkgname::git+https://github.com/duplessisaurore/quark3.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$_pkgname"
  grep '^version' Cargo.toml | head -n1 | cut -d'"' -f2 || echo "1.0.0"
}

build() {
  cd "$srcdir/$_pkgname"
  cargo build -p gluon_linker --release
}

check() {
  cd "$srcdir/$_pkgname"
  cargo test -p gluon_linker --release || true
}

package() {
  cd "$srcdir/$_pkgname"
  install -Dm755 "target/release/gluon_linker" "$pkgdir/usr/bin/gluon3"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}