# Maintainer: Aurore du Plessis <aurore@sudlicht.com>

pkgname=ink-boson3
_pkgname=boson3
pkgver=1.1.0
pkgrel=1
pkgdesc="A desugarer for the Boson3 extensions to the Quark3 textual assembly language, including named locals, globals, objects and macros."
arch=('x86_64')
url="https://github.com/duplessisaurore/quark3"
license=('AGPLv3')
depends=()
makedepends=('rust' 'cargo' 'git')
source=("$_pkgname::git+https://github.com/duplessisaurore/quark3.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$_pkgname"
  grep '^version' Cargo.toml | head -n1 | cut -d'"' -f2 || echo "1.0.0"
}

build() {
  cd "$srcdir/$_pkgname"
  cargo build -p boson_lowerer --release
}

check() {
  cd "$srcdir/$_pkgname"
  cargo test -p boson_lowerer --release || true
}

package() {
  cd "$srcdir/$_pkgname"
  install -Dm755 "target/release/boson_lowerer" "$pkgdir/usr/bin/boson3"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}